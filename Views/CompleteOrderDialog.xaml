<Window x:Class="Museum.Views.CompleteOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершение реставрации" Height="350" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата завершения:" Margin="0,5"/>
        <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding CompletionDate}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Итоговый отчёт:" Margin="0,5"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FinalReport}" TextWrapping="Wrap" Height="80" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Итоговая стоимость:" Margin="0,5"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TotalCost}" Margin="5,5,0,5"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>