<Window x:Class="Museum.Views.ExhibitEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование экспоната" Height="750" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Инвентарный номер -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Инв. номер:" Margin="0,5"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ExhibitData.InventoryNumber, UpdateSourceTrigger=PropertyChanged}" Margin="5,5,0,5"/>

        <!-- Название -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Название:" Margin="0,5"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ExhibitData.Title}" Margin="5,5,0,5"/>

        <!-- Длина -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Длина (см):" Margin="0,5"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ExhibitData.LengthCm}" Margin="5,5,0,5"/>

        <!-- Ширина -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ширина (см):" Margin="0,5"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ExhibitData.WidthCm}" Margin="5,5,0,5"/>

        <!-- Высота -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Высота (см):" Margin="0,5"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ExhibitData.HeightCm}" Margin="5,5,0,5"/>

        <!-- Дата создания -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата создания:" Margin="0,5"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ExhibitData.CreationDate}" Margin="5,5,0,5"/>

        <!-- Автор -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Автор:" Margin="0,5"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ExhibitData.Author}" Margin="5,5,0,5"/>

        <!-- Место происхождения -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Место происхождения:" Margin="0,5"/>
        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ExhibitData.OriginPlace}" Margin="5,5,0,5"/>

        <!-- Статус -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Статус:" Margin="0,5"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="8" Grid.Column="1" DisplayMemberPath="Title" 
                  ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" Margin="5,5,0,5"/>

        <!-- Акт поступления -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Акт поступления:" Margin="0,5"/>
        <ComboBox x:Name="cmbReceiptAct" Grid.Row="9" Grid.Column="1" DisplayMemberPath="ActDate" 
                  ItemsSource="{Binding ReceiptActs}" SelectedItem="{Binding SelectedReceiptAct}" Margin="5,5,0,5"/>

        <!-- Категории -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Категории:" Margin="0,5" VerticalAlignment="Top"/>
        <ListBox Grid.Row="10" Grid.Column="1" ItemsSource="{Binding SelectableCategories}" Margin="5,5,0,5" Height="70">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Category.Title}" IsChecked="{Binding IsSelected}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Материалы -->
        <TextBlock Grid.Row="11" Grid.Column="0" Text="Материалы:" Margin="0,5" VerticalAlignment="Top"/>
        <ListBox Grid.Row="11" Grid.Column="1" ItemsSource="{Binding SelectableMaterials}" Margin="5,5,0,5" Height="70">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Material.Title}" IsChecked="{Binding IsSelected}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Техники -->
        <TextBlock Grid.Row="12" Grid.Column="0" Text="Техники:" Margin="0,5" VerticalAlignment="Top"/>
        <ListBox Grid.Row="12" Grid.Column="1" ItemsSource="{Binding SelectableTechniques}" Margin="5,5,0,5" Height="70">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Technique.Title}" IsChecked="{Binding IsSelected}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="15" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>