<Window x:Class="Museum.Views.ExhibitEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование экспоната" Height="500" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Инв. номер:" Margin="0,5"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ExhibitData.InventoryNumber, UpdateSourceTrigger=PropertyChanged}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Название:" Margin="0,5"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ExhibitData.Title}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Длина (см):" Margin="0,5"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ExhibitData.LengthCm}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ширина (см):" Margin="0,5"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ExhibitData.WidthCm}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Высота (см):" Margin="0,5"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ExhibitData.HeightCm}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата создания:" Margin="0,5"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ExhibitData.CreationDate}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Автор:" Margin="0,5"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ExhibitData.Author}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Место происхождения:" Margin="0,5"/>
        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ExhibitData.OriginPlace}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Статус:" Margin="0,5"/>
        <ComboBox x:Name="cmbStatus" Grid.Row="8" Grid.Column="1" DisplayMemberPath="Title" 
                  ItemsSource="{Binding Statuses}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Акт поступления:" Margin="0,5"/>
        <ComboBox x:Name="cmbReceiptAct" Grid.Row="9" Grid.Column="1" DisplayMemberPath="ActDate" 
                  ItemsSource="{Binding ReceiptActs}" Margin="5,5,0,5"/>

        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>