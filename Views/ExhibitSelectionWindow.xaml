<Window x:Class="Museum.Views.ExhibitSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление экспонатами на выставке" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Доступные экспонаты -->
        <ListBox Grid.Column="0" ItemsSource="{Binding AvailableExhibits}" DisplayMemberPath="Title" 
                 SelectedItem="{Binding SelectedAvailableExhibit}" Margin="5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" ToolTip="{Binding InventoryNumber}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10">
            <Button Content=">>" Command="{Binding AddExhibitCommand}" Margin="0,5" Width="50"/>
            <Button Content="&lt;&lt;" Command="{Binding RemoveExhibitCommand}" Margin="0,5" Width="50"/>
        </StackPanel>

        <!-- Добавленные экспонаты с возможностью редактирования места -->
        <DataGrid Grid.Column="2" ItemsSource="{Binding AddedLinks}" AutoGenerateColumns="False" Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Экспонат" Binding="{Binding Exhibit.Title}" IsReadOnly="True"/>
                <DataGridComboBoxColumn Header="Тип места" ItemsSource="{Binding DataContext.PlaceTypes, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        DisplayMemberPath="Title" SelectedValueBinding="{Binding ExpositionPlaceTypeFk}" SelectedValuePath="Id"/>
                <DataGridTextColumn Header="Идентификатор места" Binding="{Binding PlaceIdentifier}"/>
                <DataGridTextColumn Header="Этикетка" Binding="{Binding LabelData}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>