<Window x:Class="Museum.Views.ExhibitSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление экспонатами на выставке" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Размещаем список типов мест как ресурс, чтобы он был доступен в ComboBox -->
        <CollectionViewSource x:Key="PlaceTypesSource" Source="{Binding PlaceTypes}" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Доступные экспонаты -->
        <ListBox Grid.Column="0" ItemsSource="{Binding AvailableExhibits}"
                 SelectedItem="{Binding SelectedAvailableExhibit}" Margin="5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" ToolTip="{Binding InventoryNumber}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10">
            <Button Content=">>" Click="AddExhibit_Click" Margin="0,5" Width="62"/>
            <Button Content="&lt;&lt;" Click="RemoveExhibit_Click" Margin="0,5" Width="62"/>
            <Button Content="Сохранить" Click="Save_Click" Margin="0,10,0,5" Width="62"/>
            <Button Content="Отмена" Click="Cancel_Click" Margin="0,5" Width="62"/>
        </StackPanel>

        <!-- Добавленные экспонаты -->
        <DataGrid Grid.Column="2" ItemsSource="{Binding AddedLinks}" AutoGenerateColumns="False" Margin="5">
            <DataGrid.Columns>
                <!-- Название экспоната через навигационное свойство Exhibit -->
                <DataGridTextColumn Header="Экспонат" Binding="{Binding ExhibitFkNavigation.Title}" IsReadOnly="True"/>
                <!-- Тип места – используем DataGridTemplateColumn для нормальной привязки ItemsSource -->
                <DataGridTemplateColumn Header="Тип места" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding Source={StaticResource PlaceTypesSource}}"
                                      DisplayMemberPath="Title"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding ExpositionPlaceTypeFk, UpdateSourceTrigger=PropertyChanged}"
                                      IsSynchronizedWithCurrentItem="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Идентификатор места" Binding="{Binding PlaceIdentifier}" Width="120"/>
                <DataGridTextColumn Header="Этикетка" Binding="{Binding LabelData}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!--<StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>-->
    </Grid>
</Window>