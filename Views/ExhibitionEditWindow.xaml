<Window x:Class="Museum.Views.ExhibitionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование выставки" Height="400" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" Margin="0,5"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditedExhibition.Title, UpdateSourceTrigger=PropertyChanged}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата начала:" Margin="0,5"/>
        <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding EditedExhibition.StartDate}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата окончания:" Margin="0,5"/>
        <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding EditedExhibition.EndDate}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Зал:" Margin="0,5"/>
        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Halls}" DisplayMemberPath="Title" 
                  SelectedValue="{Binding EditedExhibition.HallFk}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Куратор:" Margin="0,5"/>
        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Curators}" DisplayMemberPath="FullName" 
                  SelectedValue="{Binding EditedExhibition.ResponsibleCuratorFk}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Статус:" Margin="0,5"/>
        <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding Statuses}" DisplayMemberPath="Title" 
                  SelectedValue="{Binding EditedExhibition.ExhibitionStatusFk}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>