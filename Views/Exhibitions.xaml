<UserControl x:Class="Museum.Views.Exhibitions"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Museum.Helpers">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить" Command="{Binding AddExhibitionCommand}" Margin="0,0,5,0"/>
            <Button Content="Редактировать" Command="{Binding EditExhibitionCommand}" Margin="0,0,5,0"/>
            <Button Content="Удалить" Command="{Binding DeleteExhibitionCommand}" Margin="0,0,5,0"/>
            <Button Content="Экспонаты" Command="{Binding ManageExhibitsCommand}" Margin="0,0,5,0"/>
            <Button Content="Обновить" Command="{Binding LoadExhibitionsCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Exhibitions}" 
                  SelectedItem="{Binding SelectedExhibition}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  ScrollViewer.CanContentScroll="True"
                  HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Зал" Binding="{Binding HallTitle}" Width="150"/>
                <DataGridTextColumn Header="Куратор" Binding="{Binding CuratorFullName}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding ExhibitionStatusTitle}" Width="120"/>
                <DataGridTextColumn Header="Экспонаты" Binding="{Binding ExhibitsString}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Background="White" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Загрузка..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
        </Border>
    </Grid>
</UserControl>