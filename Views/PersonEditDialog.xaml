<Window x:Class="Museum.Views.PersonEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование человека" Height="400" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО / Название:" Margin="0,5"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditedPerson.FullName, UpdateSourceTrigger=PropertyChanged}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип лица:" Margin="0,5"/>
        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding PersonTypes}" DisplayMemberPath="TypeName"
                  SelectedValue="{Binding EditedPerson.PersonTypeFk}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" Margin="0,5"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditedPerson.ContactPhone}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:" Margin="0,5"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditedPerson.ContactEmail}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Роли:" Margin="0,5" VerticalAlignment="Top"/>
        <ListBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Roles}" DisplayMemberPath="Title"
                 SelectionMode="Multiple" Margin="5,5,0,5" Height="120">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>