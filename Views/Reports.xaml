<UserControl x:Class="Museum.Views.Reports"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl>
        <!-- Отчёт 1: Посещаемость выставок -->
        <TabItem Header="Посещаемость выставок">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Margin="0,0,10,0"/>
                    <Button Content="Сформировать отчёт" Command="{Binding GenerateAttendanceReportCommand}" Width="150"/>
                </StackPanel>
                <DataGrid Grid.Row="2" ItemsSource="{Binding AttendanceReportRows}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Выставка" Binding="{Binding ExhibitionTitle}" Width="200"/>
                        <DataGridTextColumn Header="Посетителей" Binding="{Binding VisitorsCount}" Width="100"/>
                        <DataGridTextColumn Header="Выручка" Binding="{Binding Revenue, StringFormat=N2}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

        <!-- Отчёт 2: Экспонаты на реставрации (активные заказы) -->
        <TabItem Header="Экспонаты на реставрации">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button Content="Обновить" Command="{Binding LoadRestorationOrdersCommand}" Width="100" Margin="0,0,0,10"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding RestorationOrders}" 
                  AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Экспонат" Binding="{Binding ExhibitFkNavigation.Title}" Width="200"/>
                        <DataGridTextColumn Header="Инв. номер" Binding="{Binding ExhibitFkNavigation.InventoryNumber}" Width="100"/>
                        <DataGridTextColumn Header="Дата приёма" Binding="{Binding ReceiptDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Плановая дата" Binding="{Binding PlannedCompletionDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Реставратор" Binding="{Binding RestorerFkNavigation.FullName}" Width="150"/>
                        <DataGridTextColumn Header="Требуемые работы" Binding="{Binding RequiredWorksString}" Width="200"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

        <!-- Отчёт 3: История реставраций по экспонату -->
        <TabItem Header="История реставраций">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ComboBox ItemsSource="{Binding AllExhibits}" DisplayMemberPath="Title"
                              SelectedItem="{Binding SelectedExhibitForHistory}" Width="250" Margin="0,0,10,0"/>
                    <Button Content="Показать историю" Command="{Binding LoadRestorationHistoryCommand}" Width="120"/>
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding RestorationHistoryRows}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderNumber}" Width="100"/>
                        <DataGridTextColumn Header="Дата приёма" Binding="{Binding ReceiptDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Плановая дата" Binding="{Binding PlannedCompletionDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Дата завершения" Binding="{Binding CompletionDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Дата возврата" Binding="{Binding ReturnDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>