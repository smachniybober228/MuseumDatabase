<Window x:Class="Museum.Views.RestorationOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Реставрационный заказ" Height="600" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Экспонат:" Margin="0,5"/>
        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Exhibits}" DisplayMemberPath="Title"
                  SelectedValue="{Binding Order.ExhibitFk}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Реставратор:" Margin="0,5"/>
        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Restorers}" DisplayMemberPath="FullName"
                  SelectedValue="{Binding Order.RestorerFk}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Инициатор (хранитель):" Margin="0,5"/>
        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Initiators}" DisplayMemberPath="FullName"
                  SelectedValue="{Binding Order.InitiatorFk}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата приёма:" Margin="0,5"/>
        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding Order.ReceiptDate}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Плановая дата:" Margin="0,5"/>
        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding Order.PlannedCompletionDate}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Причина:" Margin="0,5"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Order.ReasonDirection}" TextWrapping="Wrap" Height="60" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Требуемые виды работ:" Margin="0,5" VerticalAlignment="Top"/>
        <ListBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding WorkTypes}" DisplayMemberPath="Title" SelectionMode="Multiple"
                 Margin="5,5,0,5" Height="120">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>