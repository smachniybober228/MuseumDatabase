<Window x:Class="Museum.Views.ReturnExhibitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Возврат экспоната" Height="200" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата возврата:" Margin="0,5"/>
        <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding ReturnDate}" Margin="5,5,0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Новый статус:" Margin="0,5"/>
        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Statuses}" DisplayMemberPath="Title"
                  SelectedValue="{Binding SelectedStatusId}" SelectedValuePath="Id" Margin="5,5,0,5"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить" Click="Save_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>