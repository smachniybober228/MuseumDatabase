<Window x:Class="Museum.Views.WorkLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Журнал работ" Height="400" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить запись" Click="AddEntry_Click" Margin="0,0,5,0"/>
            <Button Content="Удалить запись" Click="DeleteEntry_Click" Margin="0,0,5,0"/>
        </StackPanel>
        <DataGrid x:Name="dgWorkLogEntries" Grid.Row="1" 
                  ItemsSource="{Binding WorkLogEntries}" 
                  AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding ExecutionDate, StringFormat=d}"/>
                <DataGridTextColumn Header="Вид работы" Binding="{Binding WorkTypeFkNavigation.Title}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Сохранить и закрыть" Click="SaveAndClose_Click" Width="120" Margin="0,0,5,0"/>
            <Button Content="Закрыть" Click="Close_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>